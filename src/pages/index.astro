---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SERVICES } from '../config/site';
import DashboardMockup from '../components/DashboardMockup.astro';
import ForecastMockup from '../components/ForecastMockup.astro';
import AutomationMockup from '../components/AutomationMockup.astro';
import AgentMockup from '../components/AgentMockup.astro';

// Mapeo slug → mockup animado, para el escaparate de servicios.
const MOCKS: Record<string, any> = {
  'dashboards-ejecutivos': DashboardMockup,
  'modelamiento-predictivo': ForecastMockup,
  'automatizacion-procesos': AutomationMockup,
  'agentes-ia': AgentMockup,
};

// Escaparate de servicios del home: cada fila combina texto + su mockup.
const SHOWCASE = [
  {
    slug: 'dashboards-ejecutivos',
    eyebrow: 'Visualización',
    title: 'Dashboards ejecutivos',
    desc: 'Tu negocio en tiempo real, sin reportería manual. Cada indicador se abre hasta su origen —del total al canal, al vendedor, al producto— para que decidas en el momento, no a fin de mes.',
  },
  {
    slug: 'modelamiento-predictivo',
    eyebrow: 'Datos',
    title: 'Modelamiento de datos',
    desc: 'Conectamos tus fuentes dispersas y les damos estructura. Sobre esa base proyectamos ventas y preparamos presupuestos: del caos de planillas a una sola fuente confiable.',
  },
  {
    slug: 'automatizacion-procesos',
    eyebrow: 'Eficiencia',
    title: 'Automatización de procesos',
    desc: 'Eliminamos las tareas repetitivas que consumen a tu equipo. La reportería que tomaba un día se genera sola, sin errores y sin que nadie mueva un dato.',
  },
  {
    slug: 'agentes-ia',
    eyebrow: 'Autonomía',
    title: 'Agentes IA',
    desc: 'Software que trabaja solo: monitorea tus datos, detecta lo importante y ejecuta tareas sin que se las pidas. Se adelanta a los problemas en vez de esperar la pregunta.',
  },
];

// Stack tecnológico real para el marquee (logos en public/stack/).
const STACK = [
  { src: '/stack/anthropic.svg', name: 'Anthropic' },
  { src: '/stack/openai.svg', name: 'OpenAI' },
  { src: '/stack/perplexity.svg', name: 'Perplexity' },
  { src: '/stack/gemini.svg', name: 'Gemini' },
  { src: '/stack/googlecloud.svg', name: 'Google Cloud' },
  { src: '/stack/python.svg', name: 'Python' },
  { src: '/stack/pandas.svg', name: 'pandas' },
  { src: '/stack/numpy.svg', name: 'NumPy' },
  { src: '/stack/react.svg', name: 'React' },
  { src: '/stack/typescript.svg', name: 'TypeScript' },
  { src: '/stack/nodedotjs.svg', name: 'Node.js' },
  { src: '/stack/supabase.svg', name: 'Supabase' },
  { src: '/stack/postgresql.svg', name: 'PostgreSQL' },
  { src: '/stack/tailwindcss.svg', name: 'Tailwind CSS' },
  { src: '/stack/vercel.svg', name: 'Vercel' },
  { src: '/stack/railway.svg', name: 'Railway' },
];

// Schema de servicios para la home
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#service`,
  name: SITE.name,
  provider: { '@id': `${SITE.url}/#organization` },
  serviceType: 'Consultoría en Inteligencia Artificial y Análisis de Datos',
  areaServed: { '@type': 'Country', name: 'Chile' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios Buffo IA',
    itemListElement: SERVICES.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.title, description: s.short },
    })),
  },
};
---

<BaseLayout schema={serviceSchema}>
  <!-- HERO -->
  <section class="hero-bg relative px-8 md:px-12 pt-12 pb-14 md:pt-14 md:pb-16 overflow-hidden">
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[360px] bg-primary/6 blur-[140px] rounded-full pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <div
        class="reveal inline-flex items-center gap-2 px-4 py-1.5 bg-primary/10 border border-primary/20 text-primary text-[0.7rem] tracking-[0.17em] uppercase font-bold mb-6"
      >
        <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse"></span>
        Inteligencia artificial aplicada al negocio
      </div>
      <h1
        class="reveal reveal-delay-1 text-[2.3rem] md:text-[3.4rem] font-display leading-[1.05] tracking-[-0.02em]"
      >
        Consultoría en<br /><span class="text-primary">Inteligencia Artificial</span>
      </h1>
      <p class="reveal reveal-delay-1 text-lg md:text-xl font-display text-on-surface mt-4 mb-5" style="font-weight:600; letter-spacing:-0.01em;">
        Convertimos tus datos en decisiones.
      </p>
      <p
        class="reveal reveal-delay-2 text-base md:text-lg text-on-surface-variant max-w-2xl mx-auto mb-8 leading-relaxed"
      >
        Consultora especializada en modelamiento de datos, dashboards ejecutivos, automatización de
        procesos y agentes de inteligencia artificial aplicada a la gestión.
      </p>
      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto"
          class="btn-glow bg-primary text-on-primary px-10 py-5 font-extrabold text-base text-center"
        >
          Solicitar una conversación
        </a>
        <a
          href="/servicios"
          class="border border-outline-variant bg-surface-container-highest/20 backdrop-blur-sm text-on-surface px-10 py-5 font-bold text-base text-center hover:bg-surface-container-highest/40 hover:border-primary/25 transition-all"
        >
          Ver servicios
        </a>
      </div>
    </div>
  </section>

  <!-- PROBLEMA + SOLUCIÓN -->
  <section class="py-20 px-8 md:px-12 bg-surface-container-low border-y border-white/5" id="approach">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="space-y-5 reveal">
        <div class="text-error uppercase tracking-widest text-xs font-bold">El Conflicto</div>
        <h2 class="text-xl md:text-2xl font-display leading-snug">
          Tienes datos, reportes y herramientas. Y aun así llegas al lunes sin saber qué corregir
          primero ni qué tarea soltar.
        </h2>
        <p class="text-on-surface-variant leading-relaxed text-sm md:text-base">
          Las organizaciones no tienen déficit de información — tienen déficit de interpretación y de
          tiempo. Los datos están; la inteligencia para actuar sobre ellos y la mano que ejecuta, no.
        </p>
      </div>
      <div class="reveal reveal-delay-2 relative p-8 gradient-border">
        <div class="absolute -top-5 -left-5 bg-primary p-3.5">
          <span class="material-symbols-outlined text-on-primary text-2xl">lightbulb</span>
        </div>
        <div class="text-primary uppercase tracking-widest text-xs font-bold mb-4">La Respuesta</div>
        <p class="text-base md:text-lg mb-6 leading-relaxed text-on-surface-variant">
          "Buffo IA cubre el ciclo completo: <strong class="text-on-surface font-semibold">visualiza</strong>
          tus datos, los <strong class="text-on-surface font-semibold">proyecta</strong>, <strong class="text-on-surface font-semibold">automatiza</strong>
          lo repetitivo y despliega <strong class="text-on-surface font-semibold">agentes que actúan solos</strong>.
          Nace de las áreas comerciales: habla el idioma del negocio, no de TI."
        </p>
        <div class="flex flex-wrap gap-2">
          {['Visualiza', 'Proyecta', 'Automatiza', 'Actúa'].map((t) => (
            <span class="text-[0.7rem] tracking-wide uppercase font-bold text-primary border border-primary/25 bg-primary/5 px-3 py-1.5">{t}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS — escaparate visual con mockups -->
  <section class="py-28 px-8 md:px-12 bg-background" id="services">
    <div class="max-w-6xl mx-auto">
      <div class="mb-20 reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <p class="text-primary tracking-widest uppercase text-xs font-bold mb-3">Capacidades</p>
          <h2 class="text-[2rem] md:text-[2.4rem] font-display leading-tight max-w-2xl">
            No solo mostramos tus datos. Te decimos qué hacer con ellos.
          </h2>
        </div>
        <a
          href="/servicios"
          class="text-primary text-sm font-bold hover:underline whitespace-nowrap"
        >
          Ver todos los servicios →
        </a>
      </div>

      <div class="space-y-24 md:space-y-32">
        {
          SHOWCASE.map((s, i) => {
            const Mock = MOCKS[s.slug];
            const flip = i % 2 === 1; // filas impares: mockup a la izquierda
            return (
              <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
                <div class:list={['reveal', flip ? 'lg:order-2' : 'lg:order-1']}>
                  <p class="text-primary tracking-[0.2em] uppercase text-xs font-bold mb-4">
                    {String(i + 1).padStart(2, '0')} · {s.eyebrow}
                  </p>
                  <h3 class="text-[1.7rem] md:text-[2.1rem] font-display mb-5 leading-tight">{s.title}</h3>
                  <p class="text-on-surface-variant text-lg leading-relaxed mb-8">{s.desc}</p>
                  <a
                    href={`/servicios/${s.slug}`}
                    class="inline-flex items-center gap-2 text-primary font-bold text-sm group"
                  >
                    Conocer más
                    <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
                  </a>
                </div>
                <div class:list={['reveal reveal-delay-1', flip ? 'lg:order-1' : 'lg:order-2']}>
                  <Mock />
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- RESULTADOS (cualitativo, sin cifras inventadas) -->
  <section class="py-28 px-8 md:px-12 bg-surface-container-lowest border-y border-white/5">
    <div class="max-w-screen-2xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-baseline mb-20 gap-6">
        <div class="reveal">
          <p class="text-primary tracking-widest uppercase text-xs font-bold mb-3">Resultados</p>
          <h2 class="text-[2rem] md:text-[2.4rem] font-display">Qué cambia en tu gestión</h2>
        </div>
        <div class="hidden md:block h-px flex-grow bg-white/8 mx-10"></div>
        <div class="reveal">
          <span class="text-primary font-display text-lg">Decisiones, no solo datos</span>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-10 bg-surface-container-low border border-white/5 card-hover reveal">
          <span class="material-symbols-outlined text-primary text-4xl opacity-60 mb-5 block"
            >schedule</span
          >
          <h4 class="text-lg font-display mb-3">Menos reportería manual</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Recupera horas de tu equipo eliminando la consolidación manual de planillas y reportes.
          </p>
        </div>
        <div class="p-10 bg-surface-container-low border border-white/5 card-hover reveal reveal-delay-1">
          <span class="material-symbols-outlined text-primary text-4xl opacity-60 mb-5 block"
            >bolt</span
          >
          <h4 class="text-lg font-display mb-3">Decisiones más rápidas</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            La información llega lista para actuar, no para seguir analizándola.
          </p>
        </div>
        <div class="p-10 bg-surface-container-low border border-white/5 card-hover reveal reveal-delay-2">
          <span class="material-symbols-outlined text-primary text-4xl opacity-60 mb-5 block"
            >verified_user</span
          >
          <h4 class="text-lg font-display mb-3">Visibilidad y control</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Una vista centralizada sobre equipos, procesos y resultados críticos del negocio.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LO QUE CONSTRUIMOS -->
  <section class="py-28 px-8 md:px-12 bg-surface-container-lowest" id="portfolio">
    <div class="max-w-screen-2xl mx-auto">
      <div class="mb-16 reveal">
        <p class="text-primary tracking-widest uppercase text-xs font-bold mb-3">Portafolio</p>
        <h2 class="text-[2rem] md:text-[2.4rem] font-display">Lo que construimos</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
        <div
          class="md:col-span-8 bg-surface-container-low p-12 relative overflow-hidden border border-white/5 card-hover reveal"
        >
          <div class="relative z-10">
            <h3 class="text-primary font-display text-2xl mb-7">Área Comercial y Ventas</h3>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 text-on-surface/80">
              <li class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Reportería automatizada de
                ventas
              </li>
              <li class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Seguimiento por vendedor o
                canal
              </li>
              <li class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Dashboard vs presupuesto
              </li>
              <li class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Análisis y tendencias por
                categoría
              </li>
              <li class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Alertas y cálculos de
                quiebres de stock
              </li>
              <li class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Forecasting y preparación de
                presupuestos
              </li>
            </ul>
          </div>
          <div class="absolute right-0 bottom-0 opacity-[0.025] scale-150 rotate-6 pointer-events-none">
            <span class="material-symbols-outlined text-[18rem] text-primary">trending_up</span>
          </div>
        </div>
        <div
          class="md:col-span-4 bg-surface-container p-12 border border-white/5 card-hover reveal reveal-delay-1"
        >
          <h3 class="text-primary font-display text-xl mb-7">Área de Marketing</h3>
          <ul class="space-y-3 text-on-surface/80">
            <li class="flex items-center gap-3 text-sm">
              <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Análisis de Google Ads
            </li>
            <li class="flex items-center gap-3 text-sm">
              <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Análisis de Meta Ads
            </li>
          </ul>
        </div>
        <div
          class="md:col-span-4 bg-surface-container-high p-12 border border-white/5 card-hover reveal reveal-delay-2"
        >
          <h3 class="text-primary font-display text-xl mb-7">Área Financiera</h3>
          <ul class="space-y-3 text-on-surface/80">
            <li class="flex items-center gap-3 text-sm">
              <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Análisis de Estado de
              Resultados
            </li>
            <li class="flex items-center gap-3 text-sm">
              <span class="w-1.5 h-1.5 bg-primary flex-shrink-0"></span>Elaboración de flujo de caja
            </li>
          </ul>
        </div>
        <div class="md:col-span-8 gradient-border p-12 reveal reveal-delay-3">
          <span class="material-symbols-outlined text-primary/40 text-4xl mb-4 block">format_quote</span>
          <p class="text-xl md:text-2xl font-display leading-relaxed text-on-surface">
            "Cada solución incorpora las sugerencias estratégicas de Buffo: parámetros construidos
            tras años de experiencia comercial real y las mejores prácticas de escuelas de negocios."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- STACK TECNOLÓGICO (marquee) -->
  <section class="py-24 px-8 md:px-12 bg-background border-y border-white/5 overflow-hidden">
    <div class="max-w-5xl mx-auto text-center mb-14 reveal">
      <p class="text-primary tracking-widest uppercase text-xs font-bold mb-3">Infraestructura</p>
      <h2 class="text-[2rem] md:text-[2.4rem] font-display leading-tight mb-4">
        Tecnología de clase mundial, al servicio de tu negocio
      </h2>
      <p class="text-on-surface-variant leading-relaxed max-w-2xl mx-auto">
        Construimos sobre las mismas herramientas que usan las grandes tecnológicas. Tú ves
        decisiones simples; debajo, una base robusta, segura y escalable.
      </p>
    </div>

    <div class="marquee-mask reveal reveal-delay-1">
      <div class="marquee-track gap-10 md:gap-14">
        {[...STACK, ...STACK].map((t, i) => (
          <div class="flex items-center gap-2.5 shrink-0 group" aria-hidden={i >= STACK.length ? 'true' : undefined}>
            <img
              src={t.src}
              alt={i < STACK.length ? t.name : ''}
              loading="lazy"
              class="h-6 md:h-7 w-auto opacity-50 group-hover:opacity-100 transition-opacity duration-300"
            />
            <span class="text-sm md:text-base font-semibold text-on-surface/55 group-hover:text-on-surface transition-colors whitespace-nowrap">
              {t.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="py-28 px-8 md:px-12 bg-surface-container-low">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-primary tracking-widest uppercase text-xs font-bold mb-4 reveal">Contacto</p>
      <h2 class="text-3xl md:text-4xl font-display mb-10 leading-tight reveal">
        ¿Listo para pasar de observar datos a tomar decisiones?
      </h2>
      <div class="reveal reveal-delay-1 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={SITE.calendly}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block btn-glow bg-primary text-on-primary px-12 py-5 text-base font-extrabold tracking-tight"
        >
          Agenda una llamada de 30 minutos
        </a>
        <a
          href="/contacto"
          class="inline-block border border-outline-variant text-on-surface px-12 py-5 text-base font-bold hover:border-primary/30 transition-all"
        >
          Enviar un mensaje
        </a>
      </div>
      <p class="text-on-surface-variant text-xs mt-4 tracking-wide reveal reveal-delay-1">
        Elige el horario que más te acomode — Google Meet incluido. La primera conversación es sin
        costo.
      </p>
    </div>
  </section>
</BaseLayout>
