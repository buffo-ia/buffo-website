---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import { SITE, FOUNDER, BLOG_CATEGORIES } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const { data } = post;
const path = `/blog/${post.id}`;
const cat = BLOG_CATEGORIES[data.category];

const fmtDate = (d: Date) =>
  d.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });

// Tiempo de lectura estimado (~200 palabras/min)
const words = post.body?.split(/\s+/).length ?? 0;
const readingMin = Math.max(1, Math.round(words / 200));

// Relacionados: mismo cluster primero, luego completar con otros
const others = posts.filter((p) => p.id !== post.id && (import.meta.env.DEV || !p.data.draft));
const related = [
  ...others.filter((p) => p.data.category === data.category),
  ...others.filter((p) => p.data.category !== data.category),
].slice(0, 2);

// Schema: BlogPosting + author (Person #founder) + BreadcrumbList
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  url: new URL(path, SITE.url).href,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  image: new URL(data.cover.src, SITE.url).href,
  inLanguage: 'es-CL',
  keywords: data.keywords.join(', '),
  author: {
    '@type': 'Person',
    '@id': `${SITE.url}/#founder`,
    name: FOUNDER.name,
    url: `${SITE.url}/sobre-nosotros`,
  },
  publisher: { '@id': `${SITE.url}/#organization` },
  mainEntityOfPage: new URL(path, SITE.url).href,
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
    { '@type': 'ListItem', position: 3, name: data.title, item: new URL(path, SITE.url).href },
  ],
};
---

<BaseLayout
  title={`${data.title} | ${SITE.shortName}`}
  description={data.description}
  path={path}
  schema={[articleSchema, breadcrumbSchema]}
>
  <!-- HERO del artículo -->
  <section class="hero-bg px-8 md:px-12 pt-12 pb-12">
    <div class="max-w-3xl mx-auto">
      <div class="mb-8">
        <Breadcrumbs items={[{ label: 'Blog', href: '/blog' }, { label: data.title, href: path }]} />
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-6 text-xs">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 border border-primary/20 text-primary tracking-[0.13em] uppercase font-bold">
          <span class="material-symbols-outlined text-sm">{data.icon}</span>
          {cat.label}
        </span>
        <time datetime={data.pubDate.toISOString()} class="text-on-surface-variant/70 tracking-wide">{fmtDate(data.pubDate)}</time>
        <span class="text-on-surface-variant/40">·</span>
        <span class="text-on-surface-variant/70">{readingMin} min de lectura</span>
      </div>
      <h1 class="text-[2.2rem] md:text-[3rem] font-display leading-[1.1] tracking-[-0.02em]">{data.title}</h1>
    </div>
  </section>

  <!-- IMAGEN DE PORTADA -->
  <div class="bg-background">
    <div class="max-w-4xl mx-auto px-8 md:px-12 pt-6 md:pt-10">
      <div class="relative overflow-hidden border border-white/[0.06] aspect-[16/9]">
        <Image
          src={data.cover}
          alt={data.coverAlt}
          widths={[640, 1024, 1600]}
          sizes="(max-width: 896px) 100vw, 896px"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <!-- CUERPO -->
  <article class="px-8 md:px-12 py-16 bg-background">
    <div class="max-w-3xl mx-auto">
      <!-- Lead de respuesta directa (GEO/AEO) -->
      <p class="text-xl md:text-2xl text-on-surface leading-relaxed font-display mb-12 pb-12 border-b border-white/5" style="font-weight:600; letter-spacing:-0.01em;">
        {data.lead}
      </p>

      <div class="prose-buffo">
        <Content />
      </div>

      <!-- Cierre CTA dentro del artículo -->
      <div class="mt-14 gradient-border p-8 md:p-10">
        <h2 class="font-display text-xl md:text-2xl mb-3 leading-snug">¿Lo conversamos aplicado a tu empresa?</h2>
        <p class="text-on-surface-variant mb-6 leading-relaxed">
          La primera conversación es sin costo y sirve para ver si esto le hace sentido a tu negocio.
        </p>
        <a href={SITE.calendly} target="_blank" rel="noopener noreferrer" class="btn-glow bg-primary text-on-primary px-8 py-4 font-extrabold text-sm inline-block">
          Agenda una llamada de 30 minutos
        </a>
      </div>

      <!-- Autor -->
      <div class="mt-12">
        <AuthorBox />
      </div>
    </div>
  </article>

  <!-- RELACIONADOS -->
  {related.length > 0 && (
    <section class="px-8 md:px-12 py-16 bg-surface-container-lowest border-t border-white/5">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-display mb-8">Sigue leyendo</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map((p) => (
            <a href={`/blog/${p.id}`} class="bg-surface-container-low border border-white/5 p-7 card-hover group block">
              <span class="material-symbols-outlined text-primary text-2xl mb-4 block">{p.data.icon}</span>
              <span class="text-[0.65rem] tracking-[0.13em] uppercase font-bold text-on-surface-variant block mb-2">
                {BLOG_CATEGORIES[p.data.category].label}
              </span>
              <h3 class="font-display text-lg leading-snug group-hover:text-primary transition-colors">{p.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
