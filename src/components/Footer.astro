---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { SITE } from '../config/site';
import { SERVICES_CONTENT } from '../data/services';
const year = new Date().getFullYear();

const recursos = [
  { label: 'Blog', href: '/blog' },
  { label: 'Sobre nosotros', href: '/sobre-nosotros' },
  { label: 'Servicios', href: '/servicios' },
];
---

<footer class="bg-background border-t border-white/5">
  <div class="max-w-screen-2xl mx-auto px-8 md:px-12 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-8 mb-14">
      <!-- Marca -->
      <div class="col-span-2 md:col-span-1">
        <Image src={logo} alt="Buffo IA Consulting" class="h-8 w-auto object-contain opacity-80 mb-5" loading="lazy" />
        <p class="text-on-surface-variant text-sm leading-relaxed max-w-xs">
          Inteligencia artificial aplicada a la gestión empresarial. Para pymes y grandes empresas en
          Chile.
        </p>
      </div>

      <!-- Servicios -->
      <div>
        <p class="text-xs tracking-widest uppercase text-white/40 font-bold mb-5">Servicios</p>
        <ul class="space-y-3">
          {
            SERVICES_CONTENT.map((s) => (
              <li>
                <a
                  href={`/servicios/${s.slug}`}
                  class="text-sm text-white/55 hover:text-primary transition-colors"
                >
                  {s.navTitle}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Recursos -->
      <div>
        <p class="text-xs tracking-widest uppercase text-white/40 font-bold mb-5">Recursos</p>
        <ul class="space-y-3">
          {
            recursos.map((r) => (
              <li>
                <a href={r.href} class="text-sm text-white/55 hover:text-primary transition-colors">
                  {r.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <p class="text-xs tracking-widest uppercase text-white/40 font-bold mb-5">Contacto</p>
        <ul class="space-y-3">
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="text-sm text-white/55 hover:text-primary transition-colors break-all"
            >
              {SITE.email}
            </a>
          </li>
          <li>
            <a
              href={SITE.calendly}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/55 hover:text-primary transition-colors"
            >
              Agenda una llamada
            </a>
          </li>
          <li>
            <a
              href={SITE.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/55 hover:text-primary transition-colors"
            >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs tracking-widest uppercase text-white/25 text-center md:text-left">
        © {year} {SITE.name}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
