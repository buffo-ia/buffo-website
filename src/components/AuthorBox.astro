---
import { Image } from 'astro:assets';
import { FOUNDER, SITE } from '../config/site';
import founderPhoto from '../assets/simon-espinoza.jpg';
---

<div class="bg-surface-container-low border border-white/5 p-7 md:p-8 flex flex-col sm:flex-row gap-6 items-start">
  <Image
    src={founderPhoto}
    alt={`${FOUNDER.name} — ${FOUNDER.role} de ${SITE.shortName}`}
    width={176}
    height={176}
    class="w-20 h-20 object-cover border border-primary/20 grayscale flex-shrink-0"
    loading="lazy"
  />
  <div>
    <p class="text-primary text-[0.7rem] tracking-[0.15em] uppercase font-bold mb-2">Escrito por</p>
    <h3 class="font-display text-lg mb-1">{FOUNDER.name}</h3>
    <p class="text-on-surface-variant text-sm leading-relaxed mb-4">{FOUNDER.bio}</p>
    <div class="flex flex-wrap gap-x-5 gap-y-2">
      <a
        href={FOUNDER.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-primary text-sm font-bold hover:underline"
      >
        <span class="material-symbols-outlined text-base">link</span>
        LinkedIn
      </a>
      <a
        href="/sobre-nosotros"
        class="inline-flex items-center gap-1.5 text-on-surface/70 text-sm font-semibold hover:text-primary transition-colors"
      >
        <span class="material-symbols-outlined text-base">person</span>
        Sobre nosotros
      </a>
    </div>
  </div>
</div>
