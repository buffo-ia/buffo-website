---
// Sección reutilizable "Cómo trabajamos" en 3-4 pasos numerados.
export interface Step {
  icon: string;
  title: string;
  body: string;
}
export interface Props {
  eyebrow?: string;
  title: string;
  steps: Step[];
}
const { eyebrow = 'Metodología', title, steps } = Astro.props;
---

<section class="px-8 md:px-12 py-20 bg-surface-container-lowest border-y border-white/5">
  <div class="max-w-5xl mx-auto">
    <div class="mb-14 reveal">
      <p class="text-primary tracking-widest uppercase text-xs font-bold mb-3">{eyebrow}</p>
      <h2 class="text-[2rem] md:text-[2.4rem] font-display">{title}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/5 border border-white/5">
      {
        steps.map((s, i) => (
          <div class="bg-background p-9 reveal" class:list={[i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2', i === 3 && 'reveal-delay-3']}>
            <div class="flex items-center gap-4 mb-5">
              <span class="font-display text-primary/30 text-4xl leading-none">{String(i + 1).padStart(2, '0')}</span>
              <span class="material-symbols-outlined text-primary text-3xl">{s.icon}</span>
            </div>
            <h3 class="font-display text-xl mb-3">{s.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
