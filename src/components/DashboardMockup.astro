---
// Mockup de un dashboard ejecutivo "pro" — 100% SVG/CSS animado, sin imágenes ni librerías.
// Datos de ejemplo ficticios e ilustrativos.

// ----- Área: Ventas vs Meta (6 meses) -----
const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun'];
const ventas = [58, 64, 61, 76, 72, 90];
const metas = [60, 62, 66, 70, 74, 80];
const AW = 340, AH = 150;
const apad = { t: 14, r: 8, b: 22, l: 26 };
const aiW = AW - apad.l - apad.r;
const aiH = AH - apad.t - apad.b;
const aMax = 100;
const ax = (i: number) => apad.l + (i * aiW) / (ventas.length - 1);
const ay = (v: number) => apad.t + aiH - (v / aMax) * aiH;
const ventasLine = ventas.map((v, i) => `${ax(i)},${ay(v)}`).join(' ');
const metaLine = metas.map((v, i) => `${ax(i)},${ay(v)}`).join(' ');
const areaPath = `M ${ax(0)},${ay(ventas[0])} ` + ventas.map((v, i) => `L ${ax(i)},${ay(v)}`).join(' ') + ` L ${ax(ventas.length - 1)},${apad.t + aiH} L ${ax(0)},${apad.t + aiH} Z`;

// ----- Dona: cumplimiento de meta global -----
const cumpl = 112; // % del objetivo (sobre-cumple)
const R = 46, C = 2 * Math.PI * R;
const donutPct = Math.min(cumpl, 100) / 100; // el anillo se llena hasta 100% visualmente

// ----- Ranking horizontal: top categorías (con dato + formato condicional) -----
const ranking = [
  { n: 'Cuidado capilar', v: 94, money: '$412M' },
  { n: 'Dermocosmética', v: 78, money: '$321M' },
  { n: 'Higiene', v: 63, money: '$255M' },
  { n: 'Infantil', v: 41, money: '$168M' },
];
---

<div class="dash bg-surface-container-lowest border border-white/10 p-5 md:p-6 select-none shadow-2xl shadow-primary/5">
  <!-- header app -->
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2.5">
      <span class="live-dot w-2.5 h-2.5 rounded-full bg-primary"></span>
      <span class="text-xs font-semibold text-on-surface/85 tracking-wide">Visión de Rendimiento Real</span>
    </div>
    <span class="text-[0.6rem] text-on-surface-variant/70 border border-white/10 px-2 py-1">Q2 · en vivo</span>
  </div>

  <!-- KPIs con formato condicional -->
  <div class="grid grid-cols-3 gap-2.5 mb-4">
    <div class="kpi bg-surface-container-low border border-white/5 p-3.5" style="--d:0s">
      <p class="text-[0.55rem] uppercase tracking-widest text-on-surface-variant mb-1">Ventas</p>
      <p class="text-lg md:text-xl font-display text-on-surface leading-none">$1.284M</p>
      <p class="text-[0.6rem] text-primary font-bold mt-1.5 flex items-center gap-0.5">
        <span class="material-symbols-outlined text-[0.85rem]">trending_up</span>12% vs meta
      </p>
    </div>
    <div class="kpi bg-surface-container-low border border-white/5 p-3.5" style="--d:.12s">
      <p class="text-[0.55rem] uppercase tracking-widest text-on-surface-variant mb-1">Margen</p>
      <p class="text-lg md:text-xl font-display text-on-surface leading-none">37%</p>
      <p class="text-[0.6rem] text-primary font-bold mt-1.5 flex items-center gap-0.5">
        <span class="material-symbols-outlined text-[0.85rem]">trending_up</span>+3 pts
      </p>
    </div>
    <div class="kpi bg-surface-container-low border border-error/30 p-3.5" style="--d:.24s">
      <p class="text-[0.55rem] uppercase tracking-widest text-on-surface-variant mb-1">Quiebres</p>
      <p class="text-lg md:text-xl font-display text-error leading-none">7 SKU</p>
      <p class="text-[0.6rem] text-error font-bold mt-1.5 flex items-center gap-0.5">
        <span class="material-symbols-outlined text-[0.85rem]">warning</span>acción
      </p>
    </div>
  </div>

  <!-- fila gráficos: área + dona -->
  <div class="grid grid-cols-3 gap-2.5 mb-4">
    <!-- área -->
    <div class="col-span-2 bg-surface-container-low border border-white/5 p-3.5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[0.7rem] font-semibold text-on-surface/80">Ventas vs Meta</p>
        <div class="flex items-center gap-3 text-[0.55rem] text-on-surface-variant">
          <span class="flex items-center gap-1"><span class="w-2.5 h-0.5 bg-primary inline-block"></span>Ventas</span>
          <span class="flex items-center gap-1"><span class="w-2.5 h-0 border-t border-dashed border-white/40 inline-block"></span>Meta</span>
        </div>
      </div>
      <svg viewBox={`0 0 ${AW} ${AH}`} class="w-full h-auto" role="img" aria-label="Gráfico de área: ventas versus meta mensual">
        <defs>
          <linearGradient id="areaFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#16B66B" stop-opacity="0.45" />
            <stop offset="100%" stop-color="#16B66B" stop-opacity="0" />
          </linearGradient>
        </defs>
        {[0, 50, 100].map((g) => (
          <g>
            <line x1={apad.l} x2={AW - apad.r} y1={ay(g)} y2={ay(g)} stroke="rgba(255,255,255,0.05)" />
            <text x={apad.l - 5} y={ay(g) + 3} text-anchor="end" font-size="7" fill="rgba(255,255,255,0.3)">{g}</text>
          </g>
        ))}
        <!-- relleno de área -->
        <path d={areaPath} fill="url(#areaFill)" class="area-fill" />
        <!-- línea de meta (punteada) -->
        <polyline points={metaLine} fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.5" stroke-dasharray="4 3" class="meta-line" />
        <!-- línea de ventas (animada) -->
        <polyline points={ventasLine} fill="none" stroke="#16B66B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ventas-line" />
        <!-- puntos + etiqueta del último -->
        {ventas.map((v, i) => (
          <circle cx={ax(i)} cy={ay(v)} r="2.5" fill="#16B66B" class="pt" style={`--d:${1 + i * 0.12}s`} />
        ))}
        <g class="last-label">
          <rect x={ax(5) - 22} y={ay(ventas[5]) - 20} width="26" height="14" rx="2" fill="#16B66B" />
          <text x={ax(5) - 9} y={ay(ventas[5]) - 10} text-anchor="middle" font-size="8" font-weight="700" fill="#000">90%</text>
        </g>
        {meses.map((m, i) => (
          <text x={ax(i)} y={AH - 8} text-anchor="middle" font-size="7" fill="rgba(255,255,255,0.35)">{m}</text>
        ))}
      </svg>
    </div>

    <!-- dona -->
    <div class="bg-surface-container-low border border-white/5 p-3.5 flex flex-col">
      <p class="text-[0.7rem] font-semibold text-on-surface/80 mb-1">Cumplimiento</p>
      <div class="flex-1 flex items-center justify-center relative">
        <svg viewBox="0 0 120 120" class="w-full max-w-[110px]" role="img" aria-label="Dona de cumplimiento de meta global">
          <circle cx="60" cy="60" r={R} fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="11" />
          <circle
            cx="60" cy="60" r={R} fill="none" stroke="#16B66B" stroke-width="11" stroke-linecap="round"
            transform="rotate(-90 60 60)"
            stroke-dasharray={C}
            style={`--len:${C}; --target:${C * (1 - donutPct)}`}
            class="donut-arc"
          />
          <text x="60" y="56" text-anchor="middle" font-size="22" font-weight="800" fill="#E3E2E6" font-family="Inter">112%</text>
          <text x="60" y="74" text-anchor="middle" font-size="8" fill="rgba(255,255,255,0.45)">de la meta</text>
        </svg>
      </div>
    </div>
  </div>

  <!-- ranking horizontal con etiquetas de datos -->
  <div class="bg-surface-container-low border border-white/5 p-3.5">
    <p class="text-[0.7rem] font-semibold text-on-surface/80 mb-3">Top categorías por venta</p>
    <div class="space-y-2.5">
      {ranking.map((r, i) => (
        <div class="flex items-center gap-2.5">
          <span class="text-[0.6rem] text-on-surface-variant w-24 flex-shrink-0 truncate">{r.n}</span>
          <div class="flex-1 h-4 bg-white/5 relative overflow-hidden">
            <div class="bar absolute inset-y-0 left-0 bg-gradient-to-r from-primary/70 to-primary" style={`--w:${r.v}%; --d:${0.6 + i * 0.15}s`}></div>
          </div>
          <span class="text-[0.6rem] font-bold text-on-surface w-12 text-right flex-shrink-0">{r.money}</span>
        </div>
      ))}
    </div>
  </div>

  <p class="text-[0.6rem] text-on-surface-variant/55 mt-3.5 italic">
    Ejemplo ilustrativo. Cada dashboard se construye con los KPI reales de tu negocio.
  </p>
</div>

<style>
  /* aparición de KPIs */
  .kpi {
    opacity: 0;
    transform: translateY(10px);
    animation: kpiIn 0.5s ease forwards;
    animation-delay: var(--d);
  }
  @keyframes kpiIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* línea de ventas: se dibuja */
  .ventas-line {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: draw 1.6s ease forwards 0.2s;
  }
  .meta-line {
    opacity: 0;
    animation: fade 0.6s ease forwards 1s;
  }
  @keyframes draw { to { stroke-dashoffset: 0; } }
  @keyframes fade { to { opacity: 1; } }

  /* relleno de área aparece tras la línea */
  .area-fill {
    opacity: 0;
    animation: fade 0.9s ease forwards 1.1s;
  }

  /* puntos del gráfico */
  .pt {
    opacity: 0;
    animation: ptIn 0.3s ease forwards;
    animation-delay: var(--d);
  }
  @keyframes ptIn { to { opacity: 1; } }

  .last-label {
    opacity: 0;
    transform: scale(0.6);
    transform-origin: center;
    animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards 1.9s;
  }
  @keyframes popIn { to { opacity: 1; transform: scale(1); } }

  /* dona: barre el arco */
  .donut-arc {
    stroke-dashoffset: var(--len);
    animation: donut 1.4s ease forwards 0.5s;
  }
  @keyframes donut { to { stroke-dashoffset: var(--target); } }

  /* barras de ranking crecen */
  .bar {
    width: 0;
    animation: grow 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d);
  }
  @keyframes grow { to { width: var(--w); } }

  /* punto "en vivo" latiendo */
  .live-dot {
    animation: pulse 1.8s ease-in-out infinite;
    box-shadow: 0 0 0 0 rgba(22, 182, 107, 0.5);
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(22, 182, 107, 0.5); }
    70% { box-shadow: 0 0 0 6px rgba(22, 182, 107, 0); }
    100% { box-shadow: 0 0 0 0 rgba(22, 182, 107, 0); }
  }

  /* respeto a quienes prefieren menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    .kpi, .ventas-line, .meta-line, .area-fill, .pt, .last-label, .donut-arc, .bar, .live-dot {
      animation: none;
      opacity: 1;
      stroke-dashoffset: 0;
      transform: none;
      width: var(--w, auto);
    }
  }
</style>
